name: 🌐 连通性检测面板
desc: 流媒体解锁 / AI 服务
icon: https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Global.png
category: Custom

tiles:
  - name: check-apple
    title: Apple 区域
    icon: https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Apple_1.png
    backgroundColor: '#1d1d1f'
    collapsed: true

  - name: check-netflix
    title: Netflix
    icon: https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Netflix.png
    backgroundColor: '#e50914'
    collapsed: true

  - name: check-disney
    title: Disney+
    icon: https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Disney+.png
    backgroundColor: '#0c1c4d'
    collapsed: true

  - name: check-primevideo
    title: Prime Video
    icon: https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Prime_Video.png
    backgroundColor: '#00a8e0'
    collapsed: true

  - name: check-youtube
    title: YouTube
    icon: https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/YouTube.png
    backgroundColor: '#ff0000'
    collapsed: true

  - name: check-tiktok
    title: TikTok
    icon: https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/TikTok.png
    backgroundColor: '#010101'
    collapsed: true

  - name: check-bilibili
    title: Bilibili 港澳台
    icon: https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/bilibili_3.png
    backgroundColor: '#fb7299'
    collapsed: true

  - name: check-spotify
    title: Spotify
    icon: https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Spotify.png
    backgroundColor: '#1db954'
    collapsed: true

  - name: check-chatgpt
    title: ChatGPT
    icon: https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/ChatGPT.png
    backgroundColor: '#10a37f'
    collapsed: true

  - name: check-gemini
    title: Gemini
    icon: https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Google_Search.png
    backgroundColor: '#1a73e8'
    collapsed: true

  - name: check-claude
    title: Claude
    icon: https://github.com/shindgewongxj/WHATSINStash/raw/main/icon/anthropic.png
    backgroundColor: '#cc9b7a'
    collapsed: true

script-providers:
  check-apple:
    url: https://raw.githubusercontent.com/shenguanqing/stash-panels/main/override/scripts/check-apple.js
    interval: 86400
  check-netflix:
    url: https://raw.githubusercontent.com/shenguanqing/stash-panels/main/override/scripts/check-netflix.js
    interval: 86400
  check-disney:
    url: https://raw.githubusercontent.com/shenguanqing/stash-panels/main/override/scripts/check-disney.js
    interval: 86400
  check-primevideo:
    url: https://raw.githubusercontent.com/shenguanqing/stash-panels/main/override/scripts/check-primevideo.js
    interval: 86400
  check-youtube:
    url: https://raw.githubusercontent.com/shenguanqing/stash-panels/main/override/scripts/check-youtube.js
    interval: 86400
  check-tiktok:
    url: https://raw.githubusercontent.com/shenguanqing/stash-panels/main/override/scripts/check-tiktok.js
    interval: 86400
  check-bilibili:
    url: https://raw.githubusercontent.com/shenguanqing/stash-panels/main/override/scripts/check-bilibili.js
    interval: 86400
  check-spotify:
    url: https://raw.githubusercontent.com/shenguanqing/stash-panels/main/override/scripts/check-spotify.js
    interval: 86400
  check-chatgpt:
    url: https://raw.githubusercontent.com/shenguanqing/stash-panels/main/override/scripts/check-chatgpt.js
    interval: 86400
  check-gemini:
    url: https://raw.githubusercontent.com/shenguanqing/stash-panels/main/override/scripts/check-gemini.js
    interval: 86400
  check-claude:
    url: https://raw.githubusercontent.com/shenguanqing/stash-panels/main/override/scripts/check-claude.js
    interval: 86400
